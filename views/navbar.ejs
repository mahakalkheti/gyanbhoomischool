<head>
    <link rel="stylesheet" href="/stylesheet/navbar.css">

    <script type="text/javascript">
        function googleTranslateElementInit() {
            new google.translate.TranslateElement(
                {pageLanguage: 'en', includedLanguages: 'en,hi'},
                'google_translate_element'
            );
        }

        function changeLanguage(lang) {
            var selectField = document.querySelector(".goog-te-combo");
            if (selectField) {
                selectField.value = lang;
                selectField.dispatchEvent(new Event('change'));
            }
        }

        function toggleMenu() {
            document.getElementById("navMenu").classList.toggle("active");
        }
    </script>
</head>
<body>

    <nav class="navbar">
        <div class="logo">GBPHS SCHOOL</div>
        
        <ul class="nav-links" id="navMenu">
            <li><a href="/">Home</a></li>
            <li><a href="/study-metrial">Study Material</a></li>
            <li><a href="/test">Test</a></li>
            <!-- <li><a href="/Teacher">School Staff</a></li> -->

        </ul>

        <div class="nav-right">
            <button class="lang-btn" onclick="changeLanguage('en')">English</button>
            <button class="lang-btn" onclick="changeLanguage('hi')">हिन्दी</button>
            <div class="menu-icon" onclick="toggleMenu()">☰</div>
        </div>
    </nav>

    <div id="google_translate_element" style="display: none;"></div>
    <script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

</body>
