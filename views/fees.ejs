<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>School Fee Payment</title>
</head>
<body>
    <form id="payment-form">
        <input type="text" id="studentName" placeholder="Student Name" />
        <input type="text" id="studentClass" placeholder="Class" />
        <input type="number" id="amount" placeholder="Amount" min="1" />
        <button type="button" id="pay-btn">Pay Now</button>
    </form>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        document.getElementById("pay-btn").onclick = async function () {
            const studentName = document.getElementById("studentName").value.trim();
            const studentClass = document.getElementById("studentClass").value.trim();
            const amount = Number(document.getElementById("amount").value);

            if (!studentName || !studentClass || !amount || amount <= 0) {
                alert("Please fill student name, class, and a valid amount.");
                return;
            }

            try {
                const res = await fetch("/create-order", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ amount }),
                });

                if (!res.ok) {
                    throw new Error("Order creation failed");
                }

                const order = await res.json();

                const options = {
                    key: "<%= razorpayKeyId %>",
                    amount: order.amount,
                    currency: "INR",
                    name: "School Fees Payment",
                    description: "Fee Payment",
                    order_id: order.id,
                    handler: async function (response) {
                        const verifyRes = await fetch("/verify-payment", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify(response),
                        });

                        if (!verifyRes.ok) {
                            throw new Error("Payment verification failed");
                        }

                        const result = await verifyRes.json();

                        if (result.success) {
                            alert("Payment Successful");
                        } else {
                            alert("Payment Failed");
                        }
                    },
                    prefill: {
                        name: studentName,
                        contact: "9999999999",
                    },
                    notes: {
                        studentClass,
                    },
                    theme: {
                        color: "#0f9d58",
                    },
                };

                const rzp = new Razorpay(options);
                rzp.on("payment.failed", function (response) {
                    const reason =
                        response.error && response.error.description
                            ? response.error.description
                            : "Unknown error";
                    alert("Payment Failed: " + reason);
                });
                rzp.open();
            } catch (error) {
                console.error("Payment error:", error);
                alert("Unable to start payment. Please try again.");
            }
        };
    </script>
</body>
</html>
