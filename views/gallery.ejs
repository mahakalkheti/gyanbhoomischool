<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Image Gallery</title>
    <link rel="stylesheet" href="/stylesheet/gallery.css">
</head>

<body>
    <div class="gallery-container">
        <h1>Image Gallery</h1>
        <p>Our collection of beautiful and inspiring images!</p>
        <div class="gallery-grid">
            <div class="image-box">
                <img src="img/my_all.png" alt="Image 1">
                <div class="caption">All 12th Student & Teacher</div>
            </div>
            
            <div class="image-box">
                <img src="img/pagal.jpg" alt="Image 3">
                <div class="caption">School Staf</div>
            </div>
          
            <!-- Add more images as needed -->

            <div class="image-box">
                <img src="img/child.jpg" alt="Image 4">
                <div class="caption">student's and Teacher's</div>
            </div>

            <div class="image-box">
                <img src="img/suriyanamaskar.jpg" alt="Image 4">
                <div class="caption">student's and Teacher's</div>
            </div>
            
            
             

        </div>
    </div>

    <!-- Lightbox -->
    <div id="lightbox" class="lightbox">
        <span class="close">&times;</span>
        <img id="lightbox-img" class="lightbox-content">
        <div id="lightbox-caption" class="caption"></div>
    </div>

    <script src="/script/gallery.js"></script>
</body>

</html>