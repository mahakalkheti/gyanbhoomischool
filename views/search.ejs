<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8">
  <title>Gyan Bhoomi School Dobhi | Search Admissions</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(to right, #e0f7fa, #ffffff);
      padding: 30px;
      color: #333;
    }

    .header {
      text-align: center;
      margin-bottom: 30px;
    }

    .header h1 {
      color: #00695c;
      font-size: 32px;
      margin-bottom: 10px;
    }

    .header p {
      font-size: 18px;
      color: #444;
    }

    form {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 20px;
      margin-bottom: 30px;
      background-color: #ffffff;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 0 15px rgba(0,0,0,0.05);
    }

    label {
      font-weight: bold;
      display: block;
      margin-bottom: 5px;
    }

    input[type="date"],
    input[type="text"] {
      padding: 10px;
      width: 250px;
      border-radius: 5px;
      border: 1px solid #ccc;
      outline: none;
    }

    button {
      padding: 10px 20px;
      background-color: #00796b;
      color: white;
      border: none;
      border-radius: 5px;
      font-size: 16px;
      cursor: pointer;
      transition: 0.3s ease;
    }

    button:hover {
      background-color: #004d40;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
      background-color: #ffffff;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      border-radius: 10px;
      overflow: hidden;
    }

    th, td {
      padding: 14px;
      text-align: left;
      border-bottom: 1px solid #ddd;
    }

    th {
      background-color: #00796b;
      color: white;
    }

    tr:hover {
      background-color: #f1f1f1;
    }

    p.no-results {
      text-align: center;
      font-size: 18px;
      margin-top: 30px;
      color: #d32f2f;
    }

    @media (max-width: 600px) {
      form {
        flex-direction: column;
        align-items: center;
      }

      input[type="date"],
      input[type="text"] {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>ज्ञान भूमि स्कूल डोभी</h1>
    <p> Search Admissions / प्रवेश खोजें</p>
  </div>

  <form action="/search" method="GET">
    <div>
      <label>Search by Date of Admission:</label>
      <input type="date" name="dob">
    </div>
    <div>
      <label>Search by Class:</label>
      <input type="text" name="class" placeholder="Enter Class">
    </div>
    <div style="align-self: end;">
      <button type="submit">Search</button>
    </div>
  </form>

  <% if (results && results.length > 0) { %>
    <table>
      <tr>
        <th>Name</th>
        <th>Father</th>
        <th>Class</th>
        <th>DOB</th>
        <th>Mobile</th>
        <th>2 Mobile No.</th>
        <th>Address</th>
        <th>Samagra ID</th>
        <th>Aadhar</th>
      </tr>
      <% results.forEach(student => { %>
        <tr>
          <td><%= student.name %></td>
          <td><%= student.father %></td>
          <td><%= student.class %>th</td>
          <td><%= student.dob %></td>
          <td><%= student.mobile1 %></td>
          <td><%= student.mobile2 %></td>
          <td><%= student.address %></td>
          <td><%= student.samagra %></td>
          <td><%= student.aadhar %></td>
        </tr>
      <% }) %>
    </table>
  <% } else if (results) { %>
    <p class="no-results">कोई डेटा नहीं मिला | No results found.</p>
  <% } %>
</body>
</html>
