<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gyan Bhoomi School - Home</title>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
        integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/stylesheet/p-one.css" />
</head>

<body>

    <div class="p-t-container">

        <marquee class="announcement">🎉 Admission Open for Session 2025-26 🎉</marquee>

        <div class="content">
            <div class="p-one">

                <!-- Welcome Text -->
                <div class="welcome-text">
                    <div class="small">WELCOME TO</div>
                    <div class="large">GYAN BHOOMI</div>
                    <div class="small">SCHOOL DOBHI</div>
                </div>

                <!-- Description -->
                <div class="description">
                    ज्ञान भूमि स्कूल डोभी उच्च गुणवत्ता वाली शिक्षा प्रदान करने और सीखने के प्रति प्रेम विकसित करने के लिए समर्पित है।
                    हमारा ध्यान शैक्षणिक उत्कृष्टता, समग्र विकास और मजबूत मूल्यों के साथ भविष्य के नेताओं के पोषण पर केंद्रित है।
                </div>

                <!-- Admission Button -->
                <div class="admission-btn-container">
                    <a href="/admission" class="admission-btn">Admission Form यहाँ क्लिक करें</a>
                </div>

                <!-- Image Slider Section -->
                <div class="image-slider-container">
                    <div class="image-slider">
                        <img src="/img/school/school1.jpg" alt="School Campus">
                        <img src="/img/school/side.jpg" alt="Classroom">
                        <img src="/img/school/gate.jpg" alt="Library">
                        <img src="/img/school/toilate.jpg" alt="Playground">
                    </div>
                </div>

            </div>
        </div>

    </div>

</body>

</html>
